{
  "name": "@natsunaaa/nextjs-sheet-export",
  "version": "1.0.4",
  "description": "Declarative Excel/CSV download library for Next.js App Router",
  "license": "MIT",
  "author": "natsunaaa",
  "repository": "https://github.com/naatsunaaa/excel-download-nextjs",
  "keywords": [
    "excel",
    "xlsx",
    "csv",
    "download",
    "nextjs",
    "app-router",
    "exceljs",
    "bff",
    "export"
  ],
  "type": "module",
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./route": {
      "types": "./dist/route/index.d.ts",
      "import": "./dist/route/index.js",
      "require": "./dist/route/index.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "./dist/client/index.d.ts"
      ],
      "route": [
        "./dist/route/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  },
  "peerDependencies": {
    "next": ">=13.4.0",
    "axios": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "next": "^14.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
